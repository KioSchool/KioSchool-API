<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS"
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">
    <changeSet author="kioschool-team" id="1778412067000-1">
        <createTable tableName="daily_insight_card">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="workspace_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="reference_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="template" type="VARCHAR(32)">
                <constraints nullable="false"/>
            </column>
            <column name="best_metric_key" type="VARCHAR(64)"/>
            <column name="best_metric_percentile" type="DOUBLE"/>
            <column name="headline" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="image_url" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="payload" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>
    <changeSet author="kioschool-team" id="1778412067000-2">
        <createIndex indexName="idx_dic_workspace_date" tableName="daily_insight_card" unique="true">
            <column name="workspace_id"/>
            <column name="reference_date"/>
        </createIndex>
        <addForeignKeyConstraint
            baseColumnNames="workspace_id"
            baseTableName="daily_insight_card"
            constraintName="fk_dic_workspace"
            referencedColumnNames="id"
            referencedTableName="workspace"/>
    </changeSet>
</databaseChangeLog>
